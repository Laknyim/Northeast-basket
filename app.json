{
  "expo": {
    "name": "Northeast Basket",
    "slug": "longleng-basket",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "longlengbasket",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D7A3A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.longlengbasket"
    },
    "android": {
      "package": "com.longlengbasket",
      "adaptiveIcon": {
        "backgroundColor": "#2D7A3A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "output": "single",
      "bundler": "metro"
    },
    "plugins": [
  [
    "expo-router",
    { "origin": "https://northeast-basket.vercel.app/" }
  ]
]
        
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
